MODEL_BACKEND=omlx
AGENT_RUNTIME=hermes
SANDBOX_BACKEND=multipass
MODEL_DIR=$HOME/.lmstudio/models
OLLAMA_MODELS=$HOME/.ollama/models
MODEL_CLEAN_MIN_AGE_HOURS=1

RAG_ENABLED=1
RAG_SOURCE_PATH=${OBSIDIAN_SHARED_PATH:-}
RAG_INDEX_PATH=.runtime/rag
RAG_HOST=127.0.0.1
RAG_BIND_HOST=0.0.0.0
RAG_PORT=8765
RAG_BASE_URL=http://127.0.0.1:8765
RAG_BASE_URL_GUEST=http://rag-host.internal:8765
RAG_BASE_URL_DOCKER=http://rag-host.internal:8765
RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small
RAG_EMBEDDING_BACKEND=sentence-transformers
RAG_TEXT_EXTENSIONS=.md,.txt,.rst,.csv,.tsv,.json,.yaml,.yml,.toml,.xml,.html,.xlsx,.xlsm,.xls,.xlsb,.ods,.pdf,.png,.jpg,.jpeg,.tif,.tiff
RAG_EXCLUDE_GLOBS=.git/**,.obsidian/**,node_modules/**,.trash/**,*.env,*.key,*.pem
RAG_MAX_FILE_MB=10
RAG_DOCUMENT_MAX_FILE_MB=50
RAG_CHUNK_TOKENS=800
RAG_CHUNK_OVERLAP_TOKENS=120
RAG_TOP_K=8
RAG_AUTO_INDEX=1
RAG_WATCH_INTERVAL_SECONDS=20
RAG_WATCH_DEBOUNCE_SECONDS=3
RAG_SPREADSHEETS_ENABLED=1
RAG_SPREADSHEET_MAX_FILE_MB=50
RAG_SPREADSHEET_MAX_ROWS_PER_CHUNK=50
RAG_SPREADSHEET_MAX_ROWS_FULL=5000
RAG_SPREADSHEET_INCLUDE_HIDDEN=0
RAG_SPREADSHEET_INCLUDE_FORMULAS=1
RAG_SPREADSHEET_INCLUDE_COMMENTS=1
RAG_PDF_ENABLED=1
RAG_IMAGES_ENABLED=1
RAG_OCR_ENABLED=1
RAG_OCR_MODE=needed
RAG_OCR_LANGUAGES=rus+eng+deu
RAG_OCR_TESSDATA_PATH=.runtime/tessdata
RAG_OCR_LANGUAGE_SOURCE=https://raw.githubusercontent.com/tesseract-ocr/tessdata_fast/main
RAG_OCR_MIN_TEXT_CHARS=200
RAG_OCR_MAX_PAGES=25
RAG_OCR_DPI=200
INSTALL_RAG_OCR=1

MATRIX_MODES="hermes/docker hermes/multipass openclaw/docker openclaw/multipass"
MATRIX_RAG_SOURCE_MODE=synthetic
MATRIX_RAG_QUERY=
MATRIX_RAG_SENTINEL=
MATRIX_CHAT_TIMEOUT_SECONDS=180
MATRIX_CLEAN_MODE=once
MATRIX_TELEGRAM=disabled
MATRIX_FINAL_ACTION=pause

OMLX_PORT=8000
LMSTUDIO_PORT=1234
MODEL_BIND_HOST=0.0.0.0

OPENAI_BASE_URL=http://localhost:8000/v1
ANTHROPIC_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_NAME=

MODEL_HOST_ALIAS=model-host.internal
OBSIDIAN_SHARED_PATH=
OBSIDIAN_GUEST_PATH=/mnt/obsidian
MULTIPASS_SHARED_MODE=mount
SHARED_MOUNTS_REQUIRED=0
SNAP_INSTALL_TIMEOUT_SECONDS=180
SNAP_INSTALL_RETRIES=3
MULTIPASS_MOUNT_TIMEOUT_SECONDS=30
HERMES_INSTALL_TIMEOUT_SECONDS=900
HERMES_INSTALL_RETRIES=3
HERMES_REF=main

# Telegram gateway integration.
# TELEGRAM_BOT_TOKEN comes from @BotFather.
# TELEGRAM_USER_ID is a local convenience alias for your personal allowlist.
# TELEGRAM_ALLOWED_USERS is strongly recommended; get your numeric ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_GROUP_ALLOWED_USERS=
TELEGRAM_GROUP_ALLOWED_CHATS=
GATEWAY_ALLOWED_USERS=
GATEWAY_ALLOW_ALL_USERS=false
TELEGRAM_TARGET=vm

# Hermes dashboard web UI.
# VM target is exposed through a local SSH tunnel at http://127.0.0.1:9119.
DASHBOARD_TARGET=vm
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_TUI=1

# Optional remote dashboard access.
# Prefer Tailscale Serve for private HTTPS access. Use Cloudflare Tunnel + Access for public HTTPS.
TAILSCALE_ENABLED=0
TAILSCALE_SERVE_ENABLED=0
TAILSCALE_SERVE_MODE=serve
TAILSCALE_DASHBOARD_TARGET=
TAILSCALE_DASHBOARD_ORIGIN=
# Optional Tailscale Auth Key for automated VM node registration (e.g. tskey-auth-...)
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=
TAILSCALE_EXTRA_ARGS=
CLOUDFLARE_TUNNEL_TOKEN=

# OpenClaw runtime.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_PULL_POLICY=latest
OPENCLAW_CONTROL_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_EXPOSE_BRIDGE_PORT=0
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ALLOW_TAILSCALE_AUTH=0
OPENCLAW_CONTROL_ALLOWED_ORIGINS=
OPENCLAW_DOCKER_NAME=omlx-agent-openclaw-docker
OPENCLAW_DOCKER_CONFIG_VOLUME=omlx-agent-openclaw-config
OPENCLAW_DOCKER_WORKSPACE_VOLUME=omlx-agent-openclaw-workspace
OPENCLAW_DOCKER_AUTH_VOLUME=omlx-agent-openclaw-auth
OPENCLAW_OPENAI_BASE_URL_DOCKER=http://host.docker.internal:8000/v1
OPENCLAW_OPENAI_BASE_URL_GUEST=http://model-host.internal:8000/v1

VM_NAME=omlx-agent-ubuntu
HERMES_VM_NAME=omlx-agent-ubuntu
OPENCLAW_VM_NAME=omlx-openclaw-ubuntu
VM_CPUS=4
VM_MEMORY_MB=8192
VM_MEMORY=8G
VM_DISK_GB=80
VM_DISK=80G
VM_SSH_USER=agent
VM_SSH_KEY="$HOME/.ssh/omlx_agent_vm_ed25519"
USER_SSH_PUBLIC_KEY="$HOME/.ssh/id_ed25519.pub"
VM_SNAPSHOT_NAME=clean-agent-base
UBUNTU_MULTIPASS_IMAGE=24.04
MULTIPASS_LAUNCH_TIMEOUT=900
VM_PACKAGE_UPGRADE=false

DOCKER_NAME=omlx-agent-docker
HERMES_IMAGE=nousresearch/hermes-agent:latest
DOCKER_DATA_VOLUME=omlx-agent-docker-data
DOCKER_WORKSPACE_VOLUME=omlx-agent-docker-workspace
DOCKER_CPUS=2
DOCKER_MEMORY=4g
DOCKER_SHM_SIZE=1g
DOCKER_DASHBOARD_PORT=9120
HERMES_GATEWAY_API_PORT=8642
DOCKER_GATEWAY_API_PORT=8642
OPENAI_BASE_URL_DOCKER=http://host.docker.internal:8000/v1
ANTHROPIC_BASE_URL_DOCKER=http://host.docker.internal:8000
