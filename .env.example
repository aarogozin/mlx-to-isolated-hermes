MODEL_BACKEND=omlx
AGENT_RUNTIME=hermes
SANDBOX_BACKEND=multipass
MODEL_DIR=$HOME/.lmstudio/models

OMLX_PORT=8000
LMSTUDIO_PORT=1234
MODEL_BIND_HOST=0.0.0.0

OPENAI_BASE_URL=http://localhost:8000/v1
ANTHROPIC_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_NAME=

MODEL_HOST_ALIAS=model-host.internal
OBSIDIAN_SHARED_PATH=
OBSIDIAN_GUEST_PATH=/mnt/obsidian
MULTIPASS_SHARED_MODE=transfer
SHARED_MOUNTS_REQUIRED=0
SNAP_INSTALL_TIMEOUT_SECONDS=180
SNAP_INSTALL_RETRIES=3
MULTIPASS_MOUNT_TIMEOUT_SECONDS=30
HERMES_INSTALL_TIMEOUT_SECONDS=900
HERMES_INSTALL_RETRIES=3
HERMES_REF=main

# Telegram gateway integration.
# TELEGRAM_BOT_TOKEN comes from @BotFather.
# TELEGRAM_USER_ID is a local convenience alias for your personal allowlist.
# TELEGRAM_ALLOWED_USERS is strongly recommended; get your numeric ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_GROUP_ALLOWED_USERS=
TELEGRAM_GROUP_ALLOWED_CHATS=
GATEWAY_ALLOWED_USERS=
GATEWAY_ALLOW_ALL_USERS=false
TELEGRAM_TARGET=vm

# Hermes dashboard web UI.
# VM target is exposed through a local SSH tunnel at http://127.0.0.1:9119.
DASHBOARD_TARGET=vm
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_TUI=1

# Optional remote dashboard access.
# Prefer Tailscale Serve for private HTTPS access. Use Cloudflare Tunnel + Access for public HTTPS.
TAILSCALE_DASHBOARD_TARGET=http://127.0.0.1:9119
CLOUDFLARE_TUNNEL_TOKEN=

# OpenClaw adapter stub. Hermes is the supported runtime for 0.2.x.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_CONTROL_PORT=18789

VM_NAME=omlx-agent-ubuntu
VM_CPUS=4
VM_MEMORY_MB=8192
VM_MEMORY=8G
VM_DISK_GB=80
VM_DISK=80G
VM_SSH_USER=agent
VM_SSH_KEY="$HOME/.ssh/omlx_agent_vm_ed25519"
USER_SSH_PUBLIC_KEY="$HOME/.ssh/id_ed25519.pub"
VM_SNAPSHOT_NAME=clean-agent-base
UBUNTU_MULTIPASS_IMAGE=24.04
MULTIPASS_LAUNCH_TIMEOUT=900
VM_PACKAGE_UPGRADE=false

DOCKER_NAME=omlx-agent-docker
HERMES_IMAGE=nousresearch/hermes-agent:latest
DOCKER_DATA_VOLUME=omlx-agent-docker-data
DOCKER_WORKSPACE_VOLUME=omlx-agent-docker-workspace
DOCKER_CPUS=2
DOCKER_MEMORY=4g
DOCKER_SHM_SIZE=1g
DOCKER_DASHBOARD_PORT=9120
HERMES_GATEWAY_API_PORT=8642
DOCKER_GATEWAY_API_PORT=8642
OPENAI_BASE_URL_DOCKER=http://host.docker.internal:8000/v1
ANTHROPIC_BASE_URL_DOCKER=http://host.docker.internal:8000
