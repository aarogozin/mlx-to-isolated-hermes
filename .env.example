# =============================================================================
# ★  START HERE — configure these before running `make setup`
# =============================================================================

# ── API key (required) ────────────────────────────────────────────────────────
# Used to authenticate with the local oMLX model server.
# Any non-empty string works (e.g. a random UUID or the value below).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Model server paths ────────────────────────────────────────────────────────
# Where your local LM Studio / Ollama models are stored on this machine.
MODEL_DIR=$HOME/.lmstudio/models
OLLAMA_MODELS=$HOME/.ollama/models

# ── Agent workspace — your Obsidian vault or notes folder.
# Mounted read-write inside the agent container at /mnt/obsidian.
# The agent can read and create notes here directly.
OBSIDIAN_SHARED_PATH=

# Documents library for RAG indexing — PDFs, Word files, spreadsheets, scans.
# Mounted read-only into the RAG container only. The agent accesses it exclusively
# through rag-search, not as a direct file mount.
# Leave empty to use the same folder as OBSIDIAN_SHARED_PATH.
RAG_SOURCE_PATH=

# ── Agent persistent data directory ───────────────────────────────────────────
# All agent state lives here: config, skills, workspace, rag-search binary.
# The folder is bind-mounted into the container — files are visible on the host.
# Leave empty to use .runtime/agent inside the project directory.
# Set to an absolute path (e.g. $HOME/.local/share/omlx-agent) to keep data
# outside the project and survive `git clean`.
AGENT_DATA_DIR=

# ── Telegram bot (optional) ───────────────────────────────────────────────────
# Lets you chat with the agent via Telegram. Get a token from @BotFather.
# Get your numeric user ID from @userinfobot and put it in TELEGRAM_USER_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# =============================================================================
# Runtime selection  (defaults work for most users — change if needed)
# =============================================================================

AGENT_RUNTIME=hermes
# docker is the recommended backend. Set to multipass to use a Multipass VM (legacy).
SANDBOX_BACKEND=docker
MODEL_BACKEND=omlx
MODEL_NAME=
MODEL_CLEAN_MIN_AGE_HOURS=1

# =============================================================================
# RAG (Retrieval-Augmented Generation)
# =============================================================================

RAG_ENABLED=1
RAG_RUNTIME=docker
# RAG_SOURCE_PATH is configured in the START HERE block above.
# If left empty there, it falls back to OBSIDIAN_SHARED_PATH.
RAG_PORT=8765
RAG_BASE_URL=http://127.0.0.1:8765
RAG_BASE_URL_GUEST=http://rag-host.internal:8765
RAG_BASE_URL_DOCKER=http://rag-host.internal:8765
RAG_HOST=127.0.0.1
RAG_BIND_HOST=0.0.0.0

# Indexing
RAG_AUTO_INDEX=1
RAG_AUTO_INDEX_ON_START=1
RAG_WATCH_INTERVAL_SECONDS=20
RAG_WATCH_DEBOUNCE_SECONDS=3
RAG_INDEX_PATH=.runtime/rag
RAG_CHUNK_TOKENS=800
RAG_CHUNK_OVERLAP_TOKENS=120
RAG_TOP_K=8

# File types
RAG_TEXT_EXTENSIONS=.md,.txt,.rst,.csv,.tsv,.json,.yaml,.yml,.toml,.xml,.html,.xlsx,.xlsm,.xls,.xlsb,.ods,.pdf,.png,.jpg,.jpeg,.tif,.tiff
RAG_EXCLUDE_GLOBS=.git/**,.obsidian/**,node_modules/**,.trash/**,*.env,*.key,*.pem
RAG_MAX_FILE_MB=10
RAG_DOCUMENT_MAX_FILE_MB=50

# Spreadsheets
RAG_SPREADSHEETS_ENABLED=1
RAG_SPREADSHEET_MAX_FILE_MB=50
RAG_SPREADSHEET_MAX_ROWS_PER_CHUNK=50
RAG_SPREADSHEET_MAX_ROWS_FULL=5000
RAG_SPREADSHEET_INCLUDE_HIDDEN=0
RAG_SPREADSHEET_INCLUDE_FORMULAS=1
RAG_SPREADSHEET_INCLUDE_COMMENTS=1

# PDF / images / OCR
RAG_PDF_ENABLED=1
RAG_IMAGES_ENABLED=1
RAG_OCR_ENABLED=1
RAG_OCR_MODE=needed
RAG_OCR_LANGUAGES=rus+eng+deu
RAG_OCR_MIN_TEXT_CHARS=200
RAG_OCR_MAX_PAGES=25
RAG_OCR_DPI=200
RAG_OCR_TESSDATA_PATH=.runtime/tessdata
RAG_OCR_LANGUAGE_SOURCE=https://raw.githubusercontent.com/tesseract-ocr/tessdata_fast/main
INSTALL_RAG_OCR=0
INSTALL_RAG_HOST=0

# RAG Docker stack images and runtime settings
RAG_DOCKER_NAME=mlx-isolated-rag
RAG_DOCKER_PROJECT=mlx-isolated-rag
RAG_DOCKER_INDEX_PATH=.runtime/rag-docker
RAG_DOCKER_EMBEDDING_BACKEND=hash
RAG_DOCKER_START_TIMEOUT_SECONDS=600
RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small
RAG_EMBEDDING_BACKEND=sentence-transformers
RAG_API_IMAGE=python:3.12-slim
RAG_QDRANT_IMAGE=qdrant/qdrant:latest
RAG_TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-latest
RAG_TIKA_IMAGE=apache/tika:latest-full
RAG_DOCLING_IMAGE=quay.io/docling-project/docling-serve:latest

# =============================================================================
# oMLX model server
# =============================================================================

OMLX_PORT=8000
LMSTUDIO_PORT=1234
MODEL_BIND_HOST=0.0.0.0
OPENAI_BASE_URL=http://localhost:8000/v1
ANTHROPIC_BASE_URL=http://localhost:8000
MODEL_HOST_ALIAS=model-host.internal

# =============================================================================
# Docker agent container
# =============================================================================

DOCKER_NAME=omlx-agent-docker
HERMES_IMAGE=nousresearch/hermes-agent:latest
DOCKER_CPUS=2
DOCKER_MEMORY=4g
DOCKER_SHM_SIZE=1g
DOCKER_DASHBOARD_PORT=9120
HERMES_GATEWAY_API_PORT=8642
DOCKER_GATEWAY_API_PORT=8642
OPENAI_BASE_URL_DOCKER=http://host.docker.internal:8000/v1
ANTHROPIC_BASE_URL_DOCKER=http://host.docker.internal:8000

# Named volumes — used only if AGENT_DATA_DIR is unset and DOCKER_BIND_MOUNT=0.
DOCKER_DATA_VOLUME=omlx-agent-docker-data
DOCKER_WORKSPACE_VOLUME=omlx-agent-docker-workspace

# =============================================================================
# Dashboard and Telegram gateway
# =============================================================================

DASHBOARD_TARGET=docker
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_TUI=1
HERMES_DASHBOARD_INSECURE=1
TELEGRAM_TARGET=docker
TELEGRAM_ALLOWED_USERS=
TELEGRAM_GROUP_ALLOWED_USERS=
TELEGRAM_GROUP_ALLOWED_CHATS=
GATEWAY_ALLOWED_USERS=
GATEWAY_ALLOW_ALL_USERS=false

# Optional remote dashboard via Cloudflare Tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# OpenClaw (alternative agent runtime — optional)
# =============================================================================

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_PULL_POLICY=latest
OPENCLAW_CONTROL_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_EXPOSE_BRIDGE_PORT=0
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CONTROL_ALLOWED_ORIGINS=
OPENCLAW_DOCKER_NAME=omlx-agent-openclaw-docker
OPENCLAW_DOCKER_CONFIG_VOLUME=omlx-agent-openclaw-config
OPENCLAW_DOCKER_WORKSPACE_VOLUME=omlx-agent-openclaw-workspace
OPENCLAW_DOCKER_AUTH_VOLUME=omlx-agent-openclaw-auth
OPENCLAW_OPENAI_BASE_URL_DOCKER=http://host.docker.internal:8000/v1
OPENCLAW_OPENAI_BASE_URL_GUEST=http://model-host.internal:8000/v1

# =============================================================================
# Shared mounts (Obsidian path inside container)
# =============================================================================

OBSIDIAN_GUEST_PATH=/mnt/obsidian
SHARED_MOUNTS_REQUIRED=0

# =============================================================================
# Legacy VM settings (Multipass) — only needed if SANDBOX_BACKEND=multipass
# =============================================================================

VM_NAME=omlx-agent-ubuntu
HERMES_VM_NAME=omlx-agent-ubuntu
OPENCLAW_VM_NAME=omlx-openclaw-ubuntu
VM_CPUS=4
VM_MEMORY_MB=8192
VM_MEMORY=8G
VM_DISK_GB=80
VM_DISK=80G
VM_SSH_USER=agent
VM_SSH_KEY="$HOME/.ssh/omlx_agent_vm_ed25519"
USER_SSH_PUBLIC_KEY="$HOME/.ssh/id_ed25519.pub"
VM_SNAPSHOT_NAME=clean-agent-base
UBUNTU_MULTIPASS_IMAGE=24.04
MULTIPASS_LAUNCH_TIMEOUT=900
MULTIPASS_SHARED_MODE=mount
MULTIPASS_MOUNT_TIMEOUT_SECONDS=30
SNAP_INSTALL_TIMEOUT_SECONDS=180
SNAP_INSTALL_RETRIES=3
HERMES_INSTALL_TIMEOUT_SECONDS=900
HERMES_INSTALL_RETRIES=3
HERMES_REF=main
VM_PACKAGE_UPGRADE=false

# =============================================================================
# CI / matrix end-to-end testing (not needed for normal use)
# =============================================================================

MATRIX_MODES="hermes/docker hermes/multipass openclaw/docker openclaw/multipass"
MATRIX_RAG_SOURCE_MODE=synthetic
MATRIX_RAG_QUERY=
MATRIX_RAG_SENTINEL=
MATRIX_CHAT_TIMEOUT_SECONDS=180
MATRIX_CLEAN_MODE=once
MATRIX_TELEGRAM=disabled
MATRIX_FINAL_ACTION=pause
